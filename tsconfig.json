{
  "extends": [
    "nitro/tsconfig"
  ],
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "~~/*": [
        "./*"
      ],
      "~/*": [
        "./app/*"
      ],
      "@/*": [
        "./app/*"
      ]
    }
  },
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-route-blocks",
      "vue-router/volar/sfc-typed-router"
    ]
  },
  "include": [
    "./typed-router.d.ts"
  ]
}